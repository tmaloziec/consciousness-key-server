# Consciousness Key Server — environment variables
# Copy to `.env` and adjust. `.env` is git-ignored.

# ============================================================================
# SERVER
# ============================================================================

# Listen port. Default 3040 — inside the CS ecosystem reserved range 3030-3050.
KEY_SERVER_PORT=3040

# Bind address. Use 127.0.0.1 to only serve localhost; 0.0.0.0 to expose
# on the LAN. Never expose publicly without a reverse proxy + TLS.
KEY_SERVER_HOST=127.0.0.1

# ============================================================================
# PATHS (optional — override if running outside the repo checkout)
# ============================================================================
# KEY_SERVER_KEYS_DIR=./keys
# KEY_SERVER_AUTH_CONFIG=./auth/allowed-clients.json
# KEY_SERVER_AUDIT_LOG=./logs/audit.log
